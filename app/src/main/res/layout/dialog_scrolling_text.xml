<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/scrolling_text_dialog_hint"
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        android:layout_marginBottom="8dp" />

    <EditText
        android:id="@+id/editScrollingText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_glyph_item"
        android:padding="12dp"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:inputType="textCapCharacters"
        android:singleLine="true" />

    <TextView
        android:id="@+id/labelSpeed"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/scrolling_text_speed_default"
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="8dp" />

    <SeekBar
        android:id="@+id/speedSeekBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:max="9"
        android:progress="4" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/scrolling_text_display_duration"
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="8dp" />

    <RadioGroup
        android:id="@+id/modeRadioGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <RadioButton
            android:id="@+id/radioPersistent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/scrolling_text_mode_persistent"
            android:textColor="@color/white"
            android:checked="true" />

        <RadioButton
            android:id="@+id/radioOnce"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="@string/scrolling_text_mode_once"
            android:textColor="@color/white" />

    </RadioGroup>

</LinearLayout>
