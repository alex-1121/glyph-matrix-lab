    <string name="priority_dialog_title">Select Display Mode</string>
    <string name="priority_dialog_notice">Choose whether you want your image displayed always, or only when the phone is idle. You need to update Always-on Glyph Toy setting manually depending on your choice.</string>
    <string name="priority_always_on">Always On</string>
    <string name="priority_always_desc">Choose <b>Matrix Lab: Multi function</b> on the next screen. Keeps this image on the Glyph Matrix.</string>
    <string name="priority_idle_only">Idle Only</string>
    <string name="priority_idle_desc">Choose <b>Matrix Lab: Static image</b> on the next screen. Calls and music override the image. Otherwise, this image replaces the digital clock.</string>

