    <string name="composite_dialog_title">Composite Glyph</string>
    <string name="composite_dialog_message">The Composite Glyph Toy automatically shows call status first, then the music equalizer, then a selected idle image, then the clock. Select it in the Nothing AOD toy picker to use idle images.</string>
    <string name="composite_info_intro">The Composite Glyph Toy switches between different display modes automatically based on your phone\'s state.</string>
    <string name="composite_feature_clock_title">Digital Clock</string>
    <string name="composite_feature_clock_desc">Displays the current time on the Glyph Matrix. This is the default mode when the phone is idle. Can be replaced with a custom image you create.</string>
    <string name="composite_feature_clock_preview">Clock preview on Glyph Matrix</string>
    <string name="composite_feature_equalizer_title">Equalizer</string>
    <string name="composite_feature_equalizer_desc">Visualizes currently playing audio with animated bars. Activates automatically when media is playing. Requires microphone permission.</string>
    <string name="composite_feature_equalizer_preview">Equalizer preview on Glyph Matrix</string>
    <string name="composite_feature_call_title">Call Indicator</string>
    <string name="composite_feature_call_desc">Shows a phone icon on the matrix during active calls. This has the highest priority and overrides all other modes.</string>
    <string name="composite_feature_call_preview">Call indicator preview on Glyph Matrix</string>
